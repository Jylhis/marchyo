---
import Base from '../layouts/Base.astro';
import optionsData from '../data/options.json';
import marchyoPackagesData from '../data/marchyo-packages.json';

// Serialized for the client. `<` is escaped so the JSON can never terminate the
// surrounding <script> tag early.
const optionsJson = JSON.stringify(optionsData).replace(/</g, '\\u003c');
const marchyoPackagesJson = JSON.stringify(marchyoPackagesData).replace(/</g, '\\u003c');
---

<Base
  title="marchyo search — packages & options, one index"
  description="Search every option and package Marchyo ships, from one index. Each result copies as context-ready markdown for your model."
>
  <header class="site-header">
    <div class="brand">
      <span class="ds-mark">marchyo<span class="ds-mark__chevron"> ❯</span></span>
      <span class="brand__tag">search</span>
    </div>
    <nav class="site-nav">
      <a href="/">home</a>
      <a href="/docs/introduction/">docs</a>
      <a href="https://github.com/Jylhis/marchyo">github ⑂</a>
      <button class="theme-toggle" data-theme-toggle aria-label="toggle theme">☾</button>
    </nav>
  </header>

  <main class="search" data-screen-label="Search">
    <div class="search__top">
      <label for="q" class="search__hint">$ marchyo search — packages &amp; options, one index</label>
      <div class="search__box">
        <span class="search__chev">❯</span>
        <input id="q" type="text" placeholder="try hyprland, desktop.enable, git…" autocomplete="off" spellcheck="false" />
        <span class="ds-kbd">/</span>
      </div>
      <div class="search__meta">
        <div class="tabs">
          <button class="tab is-active" data-tab="options">options <span class="tab__count" data-count="options">(0)</span></button>
          <button class="tab" data-tab="packages">packages <span class="tab__count" data-count="packages">(0)</span></button>
        </div>
        <div class="search__stats" id="stats"></div>
      </div>
    </div>

    <div class="search__grid">
      <aside class="search__aside">
        <div class="ns">
          <div class="ns__label">// namespace</div>
          <div class="ns__tree" id="ns-tree"></div>
        </div>
        <div class="ai-note">
          <div class="ai-note__label">// ai</div>
          <p>Every result copies as context-ready markdown — paste it straight into your model.</p>
          <button class="copy-chip" id="copy-all">» copy results for ai</button>
        </div>
      </aside>

      <section class="results" id="results"></section>
    </div>
  </main>

  <footer class="site-footer">
    <div class="colophon"><a href="/">marchyo(7)</a> · everything marchyo ships, one index · a reimagined <a href="https://search.nixos.org">search.nixos.org</a></div>
  </footer>

  <script type="application/json" id="options-data" is:inline set:html={optionsJson}></script>
  <script type="application/json" id="marchyo-packages-data" is:inline set:html={marchyoPackagesJson}></script>
</Base>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 24px 24px 20px;
  }
  .brand { display: flex; align-items: baseline; gap: 14px; }
  .brand__tag { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-faint); }
  .site-nav {
    display: flex;
    align-items: center;
    gap: 20px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .search {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 24px 64px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .search__top { display: flex; flex-direction: column; gap: 16px; }
  .search__hint { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-faint); }
  .search__box {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg-subtle);
    padding: 14px 18px;
    transition: border-color 0.2s ease-out;
  }
  .search__box:focus-within { border-color: var(--color-accent); }
  .search__chev { font-family: var(--font-mono); font-size: 1.2rem; color: var(--color-brand); }
  .search__box input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    outline: none;
    padding: 0;
  }
  .search__box input::placeholder { color: var(--color-text-muted); }

  .search__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .tabs { display: flex; gap: 4px; }
  .tab {
    text-align: left;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    padding: 5px 14px;
    border-radius: 3px;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    transition: color 0.15s ease-out, border-color 0.15s ease-out, background-color 0.15s ease-out;
  }
  .tab:hover { color: var(--color-accent); border-color: var(--color-accent); }
  .tab.is-active {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }
  .tab:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
  .tab__count { opacity: 0.6; }
  .search__stats { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-faint); }

  .search__grid {
    display: grid;
    grid-template-columns: 13rem minmax(0, 1fr);
    gap: 40px;
    align-items: start;
  }
  .search__aside { display: flex; flex-direction: column; gap: 20px; position: sticky; top: 24px; }
  .ns { display: flex; flex-direction: column; gap: 6px; }
  .ns__label { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-faint); }
  .ns__tree {
    display: flex;
    flex-direction: column;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 2;
    color: var(--color-text-muted);
  }
  .ai-note {
    border-left: 3px solid var(--color-brand);
    background: var(--color-bg-subtle);
    border-radius: 0 4px 4px 0;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ai-note__label { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-brand); }
  .ai-note p { margin: 0; font-family: var(--font-body); font-size: 0.9rem; line-height: 1.5; color: var(--color-text-muted); }
  .ai-note .copy-chip { align-self: flex-start; }

  .results { display: flex; flex-direction: column; }

  @media (max-width: 780px) {
    .search__grid { grid-template-columns: 1fr; }
    .search__aside { position: static; }
  }
</style>

<style is:global>
  .result {
    border-top: 1px solid var(--color-border);
    padding: 18px 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .result__head { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .result__name { font-family: var(--font-mono); font-size: 1rem; font-weight: 600; }
  .result__type { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-faint); }
  .result__version { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-syntax-string); }
  .result__license { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-faint); }
  .result__actions { margin-left: auto; display: flex; gap: 8px; }
  .result__desc { margin: 0; font-family: var(--font-body); font-size: 1rem; line-height: 1.6; color: var(--color-text-muted); }
  .result__foot { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-faint); display: flex; gap: 24px; flex-wrap: wrap; }
  .result__foot .k { color: var(--color-syntax-keyword); }
  .result-copy {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.15s ease-out, border-color 0.15s ease-out;
  }
  .result-copy:hover { color: var(--color-accent); border-color: var(--color-accent); }
  .result-empty {
    border-top: 1px solid var(--color-border);
    padding: 48px 0;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }
  .result-empty button {
    border: none;
    background: none;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-accent);
    cursor: pointer;
  }
  .result-section {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-faint);
    padding: 20px 0 4px;
    letter-spacing: 0.02em;
  }
  .result-section:first-child {
    padding-top: 0;
  }
  .result__badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-brand);
    border: 1px solid var(--color-brand);
    border-radius: 3px;
    padding: 1px 6px;
  }
  .ns__item {
    display: block;
    width: 100%;
    text-align: left;
    border: none;
    background: none;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 2;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.15s ease-out;
  }
  .ns__item:hover {
    color: var(--color-accent);
  }
  .ns__count {
    opacity: 0.5;
  }
</style>

<script>
  import Fuse from 'fuse.js';

  interface OptionRow {
    name: string;
    type: string;
    default: string;
    example: string;
    description: string;
    declared: string;
    url: string;
  }
  interface MarchyoPkg {
    attr: string;
    name: string;
    version: string;
    license: string;
    description: string;
    homepage: string;
    mainProgram: string;
    source: string;
  }
  interface NixpkgsRow {
    attr_name: string;
    pname: string;
    version: string;
    description: string | null;
    homepage: string | null;
    license: string | null;
    main_program: string | null;
  }

  function parseData<T>(id: string): T[] {
    const el = document.getElementById(id);
    if (!el || !el.textContent) return [];
    try {
      return JSON.parse(el.textContent) as T[];
    } catch {
      return [];
    }
  }

  const OPTIONS = parseData<OptionRow>('options-data');
  const MARCHYO_PKGS = parseData<MarchyoPkg>('marchyo-packages-data');

  const optionsFuse = new Fuse(OPTIONS, {
    keys: [
      { name: 'name', weight: 0.7 },
      { name: 'description', weight: 0.3 },
    ],
    threshold: 0.3,
    ignoreLocation: true,
    minMatchCharLength: 2,
  });
  const marchyoFuse = new Fuse(MARCHYO_PKGS, {
    keys: [
      { name: 'name', weight: 0.6 },
      { name: 'description', weight: 0.3 },
      { name: 'attr', weight: 0.1 },
    ],
    threshold: 0.3,
    ignoreLocation: true,
    minMatchCharLength: 2,
  });

  let q = '';
  let tab: 'options' | 'packages' = 'options';

  // nixpkgs (remote, D1-backed) state.
  let nixState: 'idle' | 'loading' | 'done' | 'error' = 'idle';
  let nixResults: NixpkgsRow[] = [];
  let nixError = '';
  let nixController: AbortController | null = null;
  let debounceTimer: number | undefined;

  const input = document.getElementById('q') as HTMLInputElement;
  const results = document.getElementById('results')!;
  const stats = document.getElementById('stats')!;
  const nsTree = document.getElementById('ns-tree')!;
  const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.tab'));
  const countEls = {
    options: document.querySelector('[data-count="options"]')!,
    packages: document.querySelector('[data-count="packages"]')!,
  };

  const esc = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

  function filteredOptions(): OptionRow[] {
    const query = q.trim();
    return query ? optionsFuse.search(query).map((r) => r.item) : OPTIONS;
  }
  function filteredMarchyoPkgs(): MarchyoPkg[] {
    const query = q.trim();
    return query ? marchyoFuse.search(query).map((r) => r.item) : MARCHYO_PKGS;
  }

  function copyText(btn: HTMLButtonElement, text: string, done = '✓ copied') {
    navigator.clipboard.writeText(text);
    const original = btn.dataset.label || btn.textContent || '';
    btn.dataset.label = original;
    btn.textContent = done;
    setTimeout(() => (btn.textContent = original), 1600);
  }

  // ---- nixpkgs remote search (Worker /api/packages → D1 FTS5) ----
  function scheduleNixpkgs() {
    const query = q.trim();
    if (tab !== 'packages' || !query) {
      nixState = 'idle';
      nixResults = [];
      return;
    }
    window.clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(() => runNixpkgs(query), 160);
  }

  async function runNixpkgs(query: string) {
    nixController?.abort();
    nixController = new AbortController();
    nixState = 'loading';
    render();
    try {
      const res = await fetch(`/api/packages?q=${encodeURIComponent(query)}`, {
        signal: nixController.signal,
        headers: { accept: 'application/json' },
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = (await res.json()) as { results?: NixpkgsRow[]; error?: string };
      if (query !== q.trim()) return; // a newer query superseded this one
      nixResults = data.results ?? [];
      nixError = data.error ?? '';
      nixState = data.error ? 'error' : 'done';
    } catch (e) {
      if ((e as Error).name === 'AbortError') return;
      nixResults = [];
      nixError = (e as Error).message;
      nixState = 'error';
    }
    render();
  }

  // ---- rendering ----
  function sectionHeader(label: string): HTMLElement {
    const el = document.createElement('div');
    el.className = 'result-section';
    el.textContent = label;
    return el;
  }

  function render() {
    const opts = filteredOptions();
    const marchyoPkgs = filteredMarchyoPkgs();
    countEls.options.textContent = `(${opts.length})`;
    countEls.packages.textContent = `(${marchyoPkgs.length + nixResults.length})`;

    tabButtons.forEach((b) => b.classList.toggle('is-active', b.dataset.tab === tab));
    results.replaceChildren();

    if (tab === 'options') {
      stats.textContent = `${opts.length} option${opts.length === 1 ? '' : 's'}`;
      if (opts.length === 0) {
        results.appendChild(emptyState());
        return;
      }
      opts.forEach((r) => results.appendChild(renderOption(r)));
      return;
    }

    // packages tab: marchyo packages (local) + nixpkgs (remote)
    stats.textContent = `${marchyoPkgs.length} marchyo · ${nixResults.length} nixpkgs`;

    if (marchyoPkgs.length) {
      results.appendChild(sectionHeader('// marchyo packages'));
      marchyoPkgs.forEach((r) => results.appendChild(renderMarchyoPkg(r)));
    }

    results.appendChild(sectionHeader('// nixpkgs'));
    if (!q.trim()) {
      results.appendChild(hint('type to search all of nixpkgs…'));
    } else if (nixState === 'loading') {
      results.appendChild(hint('searching nixpkgs…'));
    } else if (nixState === 'error') {
      results.appendChild(
        hint(`nixpkgs search unavailable${nixError ? ` (${nixError})` : ''}. marchyo options & packages still work.`),
      );
    } else if (nixResults.length === 0) {
      results.appendChild(hint(`no nixpkgs packages match “${q.trim()}”.`));
    } else {
      nixResults.forEach((r) => results.appendChild(renderNixpkg(r)));
    }

    if (marchyoPkgs.length === 0 && nixResults.length === 0 && nixState !== 'loading') {
      // keep the nixpkgs hint visible; nothing else to add
    }
  }

  function hint(text: string): HTMLElement {
    const el = document.createElement('div');
    el.className = 'result-empty';
    el.textContent = text;
    return el;
  }

  function emptyState(): HTMLElement {
    const empty = document.createElement('div');
    empty.className = 'result-empty';
    empty.innerHTML = `<span style="color:var(--color-status-err)">✗</span> no matches for “${esc(q)}” — try <button data-try="desktop">desktop</button> or <button data-try="theme" data-try-tab="options">theme</button>`;
    empty.querySelectorAll<HTMLButtonElement>('button[data-try]').forEach((b) => {
      b.addEventListener('click', () => {
        q = b.dataset.try!;
        input.value = q;
        if (b.dataset.tryTab) tab = b.dataset.tryTab as 'options' | 'packages';
        scheduleNixpkgs();
        render();
      });
    });
    return empty;
  }

  function renderOption(r: OptionRow): HTMLElement {
    const el = document.createElement('article');
    el.className = 'result';
    const nameHtml = r.url
      ? `<a href="${esc(r.url)}" class="result__name" target="_blank" rel="noopener">${esc(r.name)}</a>`
      : `<span class="result__name">${esc(r.name)}</span>`;
    const exampleFoot = r.example ? `<span>example: <span class="k">${esc(r.example)}</span></span>` : '';
    el.innerHTML = `
      <div class="result__head">
        ${nameHtml}
        <span class="result__type">${esc(r.type)}</span>
        <span class="result__actions">
          <button class="result-copy" data-role="plain">⧉ copy</button>
          <button class="result-copy" data-role="ai">» ai</button>
        </span>
      </div>
      <p class="result__desc">${esc(r.description)}</p>
      <div class="result__foot">
        <span>default: <span class="k">${esc(r.default || '—')}</span></span>
        ${exampleFoot}
        <span>declared in ${esc(r.declared)}</span>
      </div>`;
    const plain = `${r.name} = ${r.default || '…'};`;
    const ai = [
      'NixOS option (marchyo flake):',
      '',
      r.name,
      `  type: ${r.type}`,
      `  default: ${r.default || '(none)'}`,
      r.example ? `  example: ${r.example}` : null,
      `  ${r.description}`,
      `  declared in: ${r.declared}`,
      r.url ? `  source: ${r.url}` : null,
    ]
      .filter((l) => l !== null)
      .join('\n');
    el.querySelector<HTMLButtonElement>('[data-role="plain"]')!.addEventListener('click', (e) =>
      copyText(e.currentTarget as HTMLButtonElement, plain, '✓'),
    );
    el.querySelector<HTMLButtonElement>('[data-role="ai"]')!.addEventListener('click', (e) =>
      copyText(e.currentTarget as HTMLButtonElement, ai),
    );
    return el;
  }

  function renderMarchyoPkg(r: MarchyoPkg): HTMLElement {
    const el = document.createElement('article');
    el.className = 'result';
    const homeFoot = r.homepage ? ` · <a href="${esc(r.homepage)}" target="_blank" rel="noopener">${esc(r.homepage)}</a>` : '';
    el.innerHTML = `
      <div class="result__head">
        <span class="result__name">${esc(r.name)}</span>
        <span class="result__version">${esc(r.version)}</span>
        <span class="result__license">${esc(r.license)}</span>
        <span class="result__badge">marchyo</span>
        <span class="result__actions">
          <button class="result-copy" data-role="plain">⧉ copy</button>
          <button class="result-copy" data-role="ai">» ai</button>
        </span>
      </div>
      <p class="result__desc">${esc(r.description)}</p>
      <div class="result__foot">└── pkgs.${esc(r.attr)} · marchyo overlay${homeFoot}</div>`;
    const plain = `environment.systemPackages = [ pkgs.${r.attr} ];`;
    const ai = [
      'Nix package (marchyo overlay):',
      '',
      `${r.name} ${r.version}${r.license ? ` (${r.license})` : ''}`,
      `  ${r.description}`,
      `  attribute: pkgs.${r.attr}`,
      r.homepage ? `  homepage: ${r.homepage}` : null,
    ]
      .filter((l) => l !== null)
      .join('\n');
    el.querySelector<HTMLButtonElement>('[data-role="plain"]')!.addEventListener('click', (e) =>
      copyText(e.currentTarget as HTMLButtonElement, plain, '✓'),
    );
    el.querySelector<HTMLButtonElement>('[data-role="ai"]')!.addEventListener('click', (e) =>
      copyText(e.currentTarget as HTMLButtonElement, ai),
    );
    return el;
  }

  function renderNixpkg(r: NixpkgsRow): HTMLElement {
    const el = document.createElement('article');
    el.className = 'result';
    const name = r.pname || r.attr_name;
    const license = r.license ? `<span class="result__license">${esc(r.license)}</span>` : '';
    const homeFoot = r.homepage ? ` · <a href="${esc(r.homepage)}" target="_blank" rel="noopener">${esc(r.homepage)}</a>` : '';
    el.innerHTML = `
      <div class="result__head">
        <span class="result__name">${esc(name)}</span>
        <span class="result__version">${esc(r.version)}</span>
        ${license}
        <span class="result__actions">
          <button class="result-copy" data-role="plain">⧉ copy</button>
          <button class="result-copy" data-role="ai">» ai</button>
        </span>
      </div>
      <p class="result__desc">${esc(r.description || '')}</p>
      <div class="result__foot">└── pkgs.${esc(r.attr_name)}${homeFoot}</div>`;
    const plain = `environment.systemPackages = [ pkgs.${r.attr_name} ];`;
    const ai = [
      'Nix package (nixpkgs):',
      '',
      `${name} ${r.version}${r.license ? ` (${r.license})` : ''}`,
      r.description ? `  ${r.description}` : null,
      `  attribute: pkgs.${r.attr_name}`,
      r.homepage ? `  homepage: ${r.homepage}` : null,
    ]
      .filter((l) => l !== null)
      .join('\n');
    el.querySelector<HTMLButtonElement>('[data-role="plain"]')!.addEventListener('click', (e) =>
      copyText(e.currentTarget as HTMLButtonElement, plain, '✓'),
    );
    el.querySelector<HTMLButtonElement>('[data-role="ai"]')!.addEventListener('click', (e) =>
      copyText(e.currentTarget as HTMLButtonElement, ai),
    );
    return el;
  }

  // ---- namespace tree (derived from options) ----
  function buildNsTree() {
    const counts = new Map<string, number>();
    OPTIONS.forEach((o) => {
      const seg = o.name.split('.').slice(0, 2).join('.');
      counts.set(seg, (counts.get(seg) ?? 0) + 1);
    });
    const entries = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0])).slice(0, 8);
    nsTree.replaceChildren();
    entries.forEach(([ns, count], i) => {
      const glyph = i === entries.length - 1 ? '└──' : '├──';
      const btn = document.createElement('button');
      btn.className = 'ns__item';
      btn.type = 'button';
      btn.innerHTML = `${glyph} ${esc(ns)} <span class="ns__count">${count}</span>`;
      btn.addEventListener('click', () => {
        q = ns;
        input.value = ns;
        tab = 'options';
        scheduleNixpkgs();
        render();
        input.focus();
      });
      nsTree.appendChild(btn);
    });
  }

  // ---- events ----
  input.addEventListener('input', () => {
    q = input.value;
    scheduleNixpkgs();
    render();
  });
  tabButtons.forEach((b) => {
    b.addEventListener('click', () => {
      tab = b.dataset.tab as 'options' | 'packages';
      scheduleNixpkgs();
      render();
    });
  });

  document.getElementById('copy-all')!.addEventListener('click', (e) => {
    let text: string;
    if (tab === 'options') {
      const list = filteredOptions();
      text =
        `Marchyo options matching "${q || '*'}":\n\n` +
        list.map((r) => `- ${r.name} (${r.type}) — ${r.description}`).join('\n');
    } else {
      const marchyoPkgs = filteredMarchyoPkgs();
      text =
        `Marchyo package search for "${q || '*'}":\n\n` +
        `## marchyo overlay\n` +
        marchyoPkgs.map((r) => `- pkgs.${r.attr} (${r.version}) — ${r.description}`).join('\n') +
        (nixResults.length
          ? `\n\n## nixpkgs\n` + nixResults.map((r) => `- pkgs.${r.attr_name} (${r.version}) — ${r.description ?? ''}`).join('\n')
          : '');
    }
    copyText(e.currentTarget as HTMLButtonElement, text);
  });

  // "/" focuses the search box (unless already typing in a field)
  window.addEventListener('keydown', (e) => {
    if (e.key === '/' && (document.activeElement as HTMLElement)?.tagName !== 'INPUT') {
      e.preventDefault();
      input.focus();
    }
  });

  // Theme toggle (shared behaviour)
  function currentTheme() {
    return document.documentElement.dataset.theme === 'dark' ? 'dark' : '';
  }
  function applyTheme(t: string) {
    if (t) document.documentElement.dataset.theme = t;
    else delete document.documentElement.dataset.theme;
    document
      .querySelectorAll<HTMLButtonElement>('[data-theme-toggle]')
      .forEach((b) => (b.textContent = t === 'dark' ? '☀' : '☾'));
  }
  applyTheme(currentTheme());
  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const t = currentTheme() === 'dark' ? '' : 'dark';
      try {
        localStorage.setItem('marchyo-theme', t);
      } catch (err) {}
      applyTheme(t);
    });
  });

  buildNsTree();
  render();
</script>
