{
  "name": "marchyo-cli-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Marchyo CLI utilities (user + admin)",
  "license": "MIT",
  "workspaces": [
    "packages/core",
    "packages/user-cli",
    "packages/dev-cli"
  ],
  "scripts": {
    "build": "bun run build:user && bun run build:dev",
    "build:user": "bun build --compile packages/user-cli/src/cli.tsx --outfile dist/marchyo",
    "build:dev": "bun build --compile packages/dev-cli/src/cli.tsx --outfile dist/marchyoctl",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "zod": "^3.23.8"
  }
}
